# Arquivo para ignorar arquivos e pastas no Git

# Pasta do Ambiente Virtual
/venv/
/.venv/
venv/
.venv/

# Arquivos de configuração de ambiente (onde está a API Key)
.env
config.json

# Arquivos de cache do Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Arquivos de log
/LOGS/
*.log
debug_*.txt

# Arquivos de configuração do VSCode
.vscode/

# arquivo json da api
config.json

# Pastas de build do PyInstaller
/dist/
/build/
*.egg-info/

# Arquivos de especificação do PyInstaller
*.spec

# Arquivos de trabalho/checkpoint (podem conter dados do usuário)
textos_para_traduzir.json
textos_traduzidos.json
textos_traduzidos_checkpoint.json

# Glossário do usuário
scripts/glossario.json

# Icone ICO gerado durante o build (fonte: assets/stz-xml.png)
assets/icon.ico

# Relatorio de compilacao Nuitka
compilation-report.xml

# MSIX packaging
msix-staging/
release/
# Gerado pelo build-msix.ps1 a partir de assets/stz-xml.png
msix/assets/
msix-signing.pfx      # chave privada — NUNCA versionar
*.msix
# .cer pode ser commitado para distribuição — não ignorado aqui

# Arquivos de build do Nuitka
build_nuitka/
nuitka_out/
/*.build/
/*.dist/
/*.onefile-build/
*.build/
*.dist/
*.onefile-build/
*.exe
*.bin
main_qt.cmd
nuitka-crash-report*.xml

# Dados de runtime gerados pelo app
tag_presets.json

# Ferramentas de desenvolvimento / agentes
.agents/
skills-lock.json
.claude/

# Arquivos do sistema
.DS_Store
Thumbs.db
desktop.ini
